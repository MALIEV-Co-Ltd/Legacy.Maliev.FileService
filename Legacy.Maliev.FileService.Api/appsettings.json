{
  "FileStorage": {
    "AllowedBuckets": [
      "maliev.com",
      "maliev-instant-quotations",
      "maliev-quotation-requests"
    ],
    "QuarantinePrefix": "_quarantine",
    "SignedUrlHours": 168
  },
  "MalwareScanner": {
    "Host": "",
    "Port": 3310,
    "TimeoutSeconds": 30
  },
  "CORS": {
    "AllowedOrigins": [
      "https://maliev.com",
      "https://www.maliev.com"
    ]
  },
  "Jwt": {
    "PublicKey": "",
    "Issuer": "https://iam.maliev.com",
    "Audience": "maliev-services"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
